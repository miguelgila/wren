# Stage 1: Build
FROM rust:1.88-bookworm AS builder

WORKDIR /usr/src/wren
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release --bin wren-controller

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/src/wren/target/release/wren-controller /usr/local/bin/wren-controller

USER 65534:65534

ENTRYPOINT ["wren-controller"]
