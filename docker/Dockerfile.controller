# Stage 1: Build
FROM rust:1.83-bookworm AS builder

WORKDIR /usr/src/bubo
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release --bin bubo-controller

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/src/bubo/target/release/bubo-controller /usr/local/bin/bubo-controller

USER 65534:65534

ENTRYPOINT ["bubo-controller"]
