# Stage 1: Build
FROM rust:1.88-bookworm AS builder

RUN rustup target add x86_64-unknown-linux-musl \
    && apt-get update \
    && apt-get install -y --no-install-recommends musl-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/wren

# Layer 1: dependencies only (cached unless Cargo.toml/Cargo.lock change)
COPY Cargo.toml Cargo.lock ./
COPY crates/wren-core/Cargo.toml crates/wren-core/Cargo.toml
COPY crates/wren-scheduler/Cargo.toml crates/wren-scheduler/Cargo.toml
COPY crates/wren-controller/Cargo.toml crates/wren-controller/Cargo.toml
COPY crates/wren-cli/Cargo.toml crates/wren-cli/Cargo.toml
RUN mkdir -p crates/wren-core/src crates/wren-scheduler/src crates/wren-controller/src crates/wren-cli/src \
    && echo "pub fn stub(){}" > crates/wren-core/src/lib.rs \
    && echo "pub fn stub(){}" > crates/wren-scheduler/src/lib.rs \
    && echo "fn main(){}" > crates/wren-controller/src/main.rs \
    && echo "fn main(){}" > crates/wren-cli/src/main.rs \
    && cargo build --release --target x86_64-unknown-linux-musl --bin wren-controller \
    && rm -rf crates/

# Layer 2: real source (only this rebuilds on code changes)
COPY crates/ crates/
RUN touch crates/wren-core/src/lib.rs crates/wren-scheduler/src/lib.rs \
          crates/wren-controller/src/main.rs crates/wren-cli/src/main.rs \
    && cargo build --release --target x86_64-unknown-linux-musl --bin wren-controller

# Stage 2: Runtime with pre-built binary (used by CI with --target runtime-prebuilt)
FROM gcr.io/distroless/static-debian12:nonroot AS runtime-prebuilt

COPY wren-controller /usr/local/bin/wren-controller

ENTRYPOINT ["/usr/local/bin/wren-controller"]

# Stage 3: Runtime (default target — builds from source)
FROM gcr.io/distroless/static-debian12:nonroot AS runtime

COPY --from=builder /usr/src/wren/target/x86_64-unknown-linux-musl/release/wren-controller /usr/local/bin/wren-controller

ENTRYPOINT ["/usr/local/bin/wren-controller"]
